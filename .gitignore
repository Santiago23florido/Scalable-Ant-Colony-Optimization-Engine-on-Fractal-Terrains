# IDE
.vscode/

# Python cache
**/__pycache__/
**/*.py[cod]

# LaTeX auxiliary output for report
docs/.latex_aux/
docs/*.aux
docs/*.bbl
docs/*.blg
docs/*.fdb_latexmk
docs/*.fls
docs/*.log
docs/*.lof
docs/*.lot
docs/*.out
docs/*.synctex.gz
docs/*.toc

# Generated figures and tables
distributed_subdomain_mpi/results/**/plots/*.png
distributed_subdomain_mpi/results/**/plots/*.tex
distributed_subdomain_hybrid_mpi_omp/results/**/plots/*.png
distributed_subdomain_hybrid_mpi_omp/results/**/plots/*.tex
docs/figures/compare_subdomain_omp/*.png
docs/figures/compare_subdomain_omp/*.tex
docs/figures/compare_omp_mpi_hybrid/*.png
docs/figures/compare_omp_mpi_hybrid/*.tex

# Build directories (any project folder)
**/build/
**/cmake-build*/
**/CMakeFiles/
**/Testing/

# CMake generated files
**/CMakeCache.txt
**/cmake_install.cmake
**/compile_commands.json
**/CTestTestfile.cmake
**/install_manifest.txt
**/Makefile

# Object files and dependency files
**/*.o
**/*.obj
**/*.lo
**/*.d

# Binaries and libraries
**/*.exe
**/*.out
**/*.app
**/*.a
**/*.so
**/*.so.*
**/*.dylib
**/*.dll
